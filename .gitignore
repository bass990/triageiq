# Secrets, never commit real credentials
.env
.env.*
!.env.example
*.key
*-credentials.json
service-account*.json
*.pem

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# Virtualenvs
.venv/
venv/
env/
ENV/

# Node, TriageIQ frontend
frontend/node_modules/
frontend/dist/
frontend/.vite/
npm-debug.log*
yarn-debug.log*

# Jupyter
.ipynb_checkpoints/
*-checkpoint.ipynb

# Build artifacts
build/
dist/

# Local data, regenerate from sources
data/cache/
data/raw/
data/processed/*.csv
data/processed/*.parquet
data/processed/*.pkl
!data/processed/.gitkeep

# OS cruft
.DS_Store
__MACOSX/
Thumbs.db
desktop.ini

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Build-history scratch files, keep locally, don't commit
CHANGES_*.md
CLAUDE_CONTEXT.md

# Generated presentation artifacts (the .pptx is built by make_pptx.py)
*.pptx
!docs/*.pptx
